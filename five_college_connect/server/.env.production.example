# Production values belong in your hosting provider's environment-variable UI.
# For the free deployment path, set these in the Vercel project settings
# instead of committing a real .env.production file.

PORT=4000
NODE_ENV=production
CLIENT_URL=https://your-client-site.vercel.app
EMAIL_VERIFICATION_BASE_URL=https://your-client-site.vercel.app/verify-email

# Use Neon pooled connections in production.
DATABASE_URL=postgresql://USERNAME:PASSWORD@YOUR-NEON-POOLER-HOST/neondb?sslmode=require&channel_binding=require
DB_SSL=true

AUTH_TOKEN_SECRET=replace_with_a_random_32_byte_secret
AUTH_TOKEN_EXPIRES_IN_HOURS=24

ALLOWED_EMAIL_DOMAINS=umass.edu,amherst.edu,smith.edu,hampshire.edu,mtholyoke.edu

# Optional email delivery in production.
MAILJET_API_KEY=
MAILJET_API_SECRET=
EMAIL_FROM=Five College Connect <noreply@example.com>
EMAIL_REPLY_TO=support@example.com
