PORT=4000
NODE_ENV=development
CLIENT_URL=http://localhost:3000

# once front end is set up, change use this instead
# EMAIL_VERIFICATION_BASE_URL=http://localhost:3000/verify-email
EMAIL_VERIFICATION_BASE_URL=http://localhost:4000/api/auth/verify-email

# Optional in local dev. When omitted, the server logs verification links
# instead of sending real emails.
# For Mailjet testing without a custom domain, verify a sender address in your
# Mailjet account, then set EMAIL_FROM to that exact address or sender name.
# Later, if we want to purchase a domain, we will change EMAIL_FROM to something like:
# Five College Connect <onboarding@fivecollegeconnect.com>
MAILJET_API_KEY=
MAILJET_API_SECRET=
EMAIL_FROM=Five College Connect <fivecollegeconnect@gmail.com>
EMAIL_REPLY_TO=fivecollegeconnect@gmail.com

# Host port 5434 matches docker-compose.yml (avoids conflicts with local
# Postgres installs on 5432/5433). Database name is five_college_connect.
DATABASE_URL=postgres://postgres:postgres@localhost:5434/five_college_connect
DB_SSL=false

AUTH_TOKEN_SECRET=replace_me
AUTH_TOKEN_EXPIRES_IN_HOURS=24

ALLOWED_EMAIL_DOMAINS=umass.edu,amherst.edu,smith.edu,hampshire.edu,mtholyoke.edu
